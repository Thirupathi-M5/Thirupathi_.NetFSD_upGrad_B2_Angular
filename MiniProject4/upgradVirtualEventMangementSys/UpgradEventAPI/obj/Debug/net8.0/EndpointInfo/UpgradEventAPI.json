  "components": {
    "schemas": {
      "CreateEventRequest": {
        "type": "object",
        "properties": {
          "eventName": {
            "type": "string",
            "nullable": true
          },
          "eventCategory": {
            "type": "string",
            "nullable": true
          },
          "eventDate": {
            "type": "string",
            "nullable": true
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CreateSpeakerRequest": {
        "type": "object",
        "properties": {
          "speakerName": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "emailId": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "RegisterRequest": {
        "type": "object",
        "properties": {
          "eventId": {
            "type": "integer",
            "format": "int32"
          },
          "sessionId": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "SessionInfo": {
        "required": [
          "eventId",
          "sessionEnd",
          "sessionStart",
          "sessionTitle"
        ],
        "type": "object",
        "properties": {
          "sessionId": {
            "type": "integer",
            "format": "int32"
          },
          "eventId": {
            "type": "integer",
            "format": "int32"
          },
          "sessionTitle": {
            "maxLength": 50,
            "minLength": 1,
            "type": "string"
          },
          "speakerId": {
            "type": "integer",
            "format": "int32"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "sessionStart": {
            "type": "string",
            "format": "date-time"
          },
          "sessionEnd": {
            "type": "string",
            "format": "date-time"
          },
          "sessionUrl": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "UserRegisterRequest": {
        "type": "object",
        "properties": {
